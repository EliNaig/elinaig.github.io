---

const pathname = Astro.url.pathname;

const nav = [
	{ href: "/", label: "Home" },
	{ href: "/research/", label: "Research" },
	{ href: "/work/", label: "Work" },
	{ href: "/publications/", label: "Publications" },
	{ href: "/now/", label: "Now" },
	{ href: "/contact/", label: "Contact" },
	{ href: "/cv/", label: "CV" },
] as const;

function isActive(href: string) {
	if (href === "/") return pathname === "/";
	return pathname.startsWith(href);
}
---

<a
	href="#content"
	class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-sm focus:bg-white focus:px-3 focus:py-2 focus:text-sm focus:font-medium focus:text-zinc-900 focus:shadow focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2 focus:ring-offset-zinc-50"
>
	Skip to content
</a>

<header class="sticky top-0 z-40 border-b border-zinc-200/80 bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/70">
	<div class="container flex items-center justify-between gap-6 py-3">
		<a href="/" class="text-sm font-semibold text-zinc-950 no-underline lg:hidden">Eli Naig</a>

		<nav class="hidden items-center gap-x-6 gap-y-2 text-sm lg:flex" aria-label="Primary navigation">
			{nav.map((item) => (
				<a
					href={item.href}
					class:list={[
						"no-underline decoration-zinc-300 underline-offset-4 hover:underline",
						isActive(item.href) ? "font-semibold text-zinc-950 decoration-zinc-400" : "text-zinc-700",
					]}
				>
					{item.label}
				</a>
			))}
		</nav>

		<details class="group relative lg:hidden">
			<summary class="flex cursor-pointer list-none items-center gap-2 rounded-sm border border-zinc-200 bg-white px-3 py-2 text-sm font-medium text-zinc-900 shadow-sm marker:hidden">
				<svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 stroke-current" fill="none" stroke-width="2">
					<path d="M4 7h16M4 12h16M4 17h16"></path>
				</svg>
				Menu
			</summary>
			<nav
				class="absolute right-0 mt-2 w-56 rounded-sm border border-zinc-200 bg-white p-2 text-sm shadow-lg"
				aria-label="Mobile navigation"
			>
				{nav.map((item) => (
					<a
						href={item.href}
						class:list={[
							"block rounded-sm px-3 py-2 no-underline hover:bg-zinc-50",
							isActive(item.href) ? "font-semibold text-zinc-950" : "text-zinc-700",
						]}
					>
						{item.label}
					</a>
				))}
			</nav>
		</details>
	</div>
</header>
