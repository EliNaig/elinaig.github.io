---
import SocialIcons from "./SocialIcons.astro";

const pathname = Astro.url.pathname;
const isHome = pathname === "/";

const nav = [
	{ href: "/", label: "About" },
	{ href: "/publications/", label: "Publications" },
	{ href: "/cv/", label: "CV" },
] as const;

function isActive(href: string) {
	if (href === "/") return pathname === "/";
	return pathname.startsWith(href);
}
---

<a href="#content" class="skip-link">Skip to content</a>

<header>
	<nav class="site-navbar" aria-label="Primary navigation">
		<div class="page-container site-navbar-inner">
			{isHome ? (
				<div class="navbar-brand social">
					<SocialIcons />
				</div>
			) : (
				<a class="navbar-brand" href="/"><strong>Eli</strong> Naig</a>
			)}

			<div class="flex items-center gap-2">
				<ul class="navbar-nav hidden list-none sm:flex" style="margin: 0; padding: 0;">
					{nav.map((item) => (
						<li>
							<a href={item.href} class:list={["nav-link", isActive(item.href) ? "active" : ""]}>
								{item.label}
							</a>
						</li>
					))}
				</ul>

				<button id="light-toggle" title="Change theme" aria-label="Change theme">
					<span id="light-toggle-system" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
							<path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 2v16a8 8 0 0 1 0-16z" />
						</svg>
					</span>
					<span id="light-toggle-dark" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
							<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
						</svg>
					</span>
					<span id="light-toggle-light" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
							<circle cx="12" cy="12" r="4" fill="currentColor" stroke="none" />
							<path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9L17 7M7 17l-2.1 2.1" />
						</svg>
					</span>
				</button>

				<details class="relative sm:hidden">
					<summary class="navbar-toggler" aria-label="Toggle navigation">
						<span class="icon-bar top-bar"></span>
						<span class="icon-bar middle-bar"></span>
						<span class="icon-bar bottom-bar"></span>
					</summary>
					<div class="mobile-menu">
						{nav.map((item) => (
							<a href={item.href} class:list={["nav-link", isActive(item.href) ? "active" : ""]}>
								{item.label}
							</a>
						))}
					</div>
				</details>
			</div>
		</div>
	</nav>
</header>

<script is:inline>
	(() => {
		const toggle = document.getElementById("light-toggle");
		if (!toggle) return;
		const order = ["system", "dark", "light"];
		toggle.addEventListener("click", () => {
			const current = document.documentElement.getAttribute("data-theme-setting") || "system";
			const next = order[(order.indexOf(current) + 1) % order.length];
			localStorage.setItem("theme-setting", next);
			document.documentElement.setAttribute("data-theme-setting", next);
			if (next === "system") {
				document.documentElement.removeAttribute("data-theme");
			} else {
				document.documentElement.setAttribute("data-theme", next);
			}
		});
	})();
</script>
