---
import { site } from "../lib/site";
---

<aside class="lg:sticky lg:top-24">
	<div class="flex flex-col items-center gap-5 text-center sm:flex-row sm:items-start sm:text-left lg:flex-col lg:text-left">
		<img
			src={site.profileImage ?? "/images/profile.png"}
			alt={`Portrait of ${site.name}`}
			width="1600"
			height="2400"
			loading="eager"
			decoding="async"
			fetchpriority="high"
			class="h-24 w-24 shrink-0 rounded-2xl object-cover sm:h-28 sm:w-28 lg:h-auto lg:w-full"
		/>

		<div class="min-w-0 space-y-4">
			<div>
				<p class="font-serif text-2xl leading-tight text-zinc-950">{site.name}</p>
				<p class="mt-2 text-sm leading-6 text-zinc-600">Mathematics student and undergraduate researcher.</p>
			</div>

			<div class="space-y-1 text-sm text-zinc-600">
				<p>{site.location}</p>
				<p>{site.affiliation}</p>
				<p class="break-words"><a href={`mailto:${site.email}`}>{site.email}</a></p>
			</div>

			<div class="flex flex-wrap justify-center gap-2 text-sm sm:justify-start lg:flex-col lg:items-start">
				{site.social.github ? <a class="pill" href={site.social.github} target="_blank" rel="noreferrer">GitHub</a> : null}
				{site.social.linkedin ? <a class="pill" href={site.social.linkedin} target="_blank" rel="noreferrer">LinkedIn</a> : null}
				{site.social.orcid ? <a class="pill" href={site.social.orcid} target="_blank" rel="noreferrer">ORCID</a> : null}
			</div>
		</div>
	</div>
</aside>
