---
import { site } from "../lib/site";
---

<aside class="lg:sticky lg:top-20">
	<div class="rounded-sm border border-zinc-200/80 bg-white p-5 shadow-sm">
		<div class="flex items-start gap-4 lg:flex-col lg:gap-5">
			<img
				src={site.profileImage ?? "/images/profile.png"}
				alt={`Portrait of ${site.name}`}
				width="1600"
				height="2400"
				loading="eager"
				decoding="async"
				fetchpriority="high"
				class="h-28 w-28 shrink-0 rounded-sm border border-zinc-200 object-cover lg:h-auto lg:w-full lg:max-w-none"
			/>

			<div class="min-w-0">
				<p class="text-lg font-semibold leading-tight text-zinc-950">{site.name}</p>
				<p class="mt-1 text-sm leading-6 text-zinc-700">
					Mathematics student • Undergraduate researcher
				</p>

				<dl class="mt-4 grid gap-3 text-sm text-zinc-800">
					<div class="grid grid-cols-[5.5rem_1fr] gap-2">
						<dt class="text-zinc-500">Location</dt>
						<dd class="min-w-0 truncate">{site.location}</dd>
					</div>
					<div class="grid grid-cols-[5.5rem_1fr] gap-2">
						<dt class="text-zinc-500">Affiliation</dt>
						<dd class="min-w-0 truncate">{site.affiliation}</dd>
					</div>
					<div class="grid grid-cols-[5.5rem_1fr] gap-2">
						<dt class="text-zinc-500">Email</dt>
						<dd class="min-w-0 truncate">
							<a href={`mailto:${site.email}`}>{site.email}</a>
						</dd>
					</div>
				</dl>

				<div class="mt-4 flex flex-wrap gap-2 text-sm">
					{site.social.github ? (
						<a class="pill inline-flex items-center gap-1.5" href={site.social.github} target="_blank" rel="noreferrer">
							<svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-current">
								<path
									d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.09 3.29 9.42 7.86 10.94.58.1.79-.25.79-.56v-2.17c-3.2.69-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.12-3.05 0 0 .97-.31 3.18 1.18a10.9 10.9 0 0 1 5.8 0c2.21-1.5 3.18-1.18 3.18-1.18.63 1.59.24 2.76.12 3.05.74.8 1.18 1.82 1.18 3.08 0 4.44-2.7 5.4-5.28 5.69.41.36.78 1.08.78 2.18v3.23c0 .31.21.67.8.56 4.56-1.52 7.84-5.85 7.84-10.94C23.5 5.66 18.35.5 12 .5Z"
								></path>
							</svg>
							<span>GitHub</span>
						</a>
					) : null}
					{site.social.linkedin ? (
						<a class="pill inline-flex items-center gap-1.5" href={site.social.linkedin} target="_blank" rel="noreferrer">
							<svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-current">
								<path
									d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45Z"
								></path>
							</svg>
							<span>LinkedIn</span>
						</a>
					) : null}
					{site.social.orcid ? (
						<a class="pill inline-flex items-center gap-1.5" href={site.social.orcid} target="_blank" rel="noreferrer">
							<svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4">
								<circle cx="12" cy="12" r="10" fill="#A6CE39"></circle>
								<text
									x="12"
									y="15"
									text-anchor="middle"
									fill="#ffffff"
									font-size="8"
									font-weight="700"
									font-family="Arial, sans-serif"
								>
									iD
								</text>
							</svg>
							<span>ORCID</span>
						</a>
					) : null}
					{site.social.youtube ? (
						<a class="pill" href={site.social.youtube} target="_blank" rel="noreferrer">YouTube</a>
					) : null}
				</div>
			</div>
		</div>
	</div>
</aside>
