---
import { site } from "../lib/site";

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-zinc-200 bg-white">
	<div class="container py-8 text-sm text-zinc-600">
		<div class="flex flex-wrap items-center justify-between gap-4">
			<p>© {year} {site.name}</p>
			<div class="flex flex-wrap items-center gap-3">
				<a class="no-underline hover:underline" href={`mailto:${site.email}`}>{site.email}</a>
				{site.social.github ? <a class="no-underline hover:underline" href={site.social.github}>GitHub</a> : null}
				{site.social.linkedin ? <a class="no-underline hover:underline" href={site.social.linkedin}>LinkedIn</a> : null}
				{site.social.orcid ? <a class="no-underline hover:underline" href={site.social.orcid}>ORCID</a> : null}
			</div>
		</div>
	</div>
</footer>
