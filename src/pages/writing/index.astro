---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

let entries = [];
try {
	entries = await getCollection("writing");
} catch {
	entries = [];
}

entries = entries.filter((e) => !e.data.draft);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SiteLayout title="Writing" description="Technical notes and research writing by Eli Naig.">
	<section class="mt-2">
		<h1>Writing</h1>
		<p class="mt-4 max-w-prose text-zinc-800">
			Short technical notes on reproducibility, coding theory, and post-quantum cryptography.
		</p>

		<div class="mt-8">
			{entries.length === 0 ? (
				<p class="rounded-sm border border-zinc-200 bg-zinc-50 p-4 text-zinc-700">No writing entries yet.</p>
			) : (
				<ol class="space-y-5">
					{entries.map((e) => (
						<li class="rounded-sm border border-zinc-200 bg-white p-6 shadow-sm">
							<div class="flex flex-wrap items-baseline justify-between gap-3">
								<h2 class="text-lg font-semibold leading-6">
									<a class="no-underline hover:underline" href={`/writing/${e.slug}/`}>{e.data.title}</a>
								</h2>
								<time class="text-xs font-medium text-zinc-500" datetime={e.data.date.toISOString()}>
									{e.data.date.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" })}
								</time>
							</div>
							<p class="mt-2 text-sm leading-6 text-zinc-700">{e.data.summary}</p>
							{e.data.tags?.length ? (
								<div class="mt-4 flex flex-wrap gap-2">
									{e.data.tags.map((t) => (
										<span class="pill">{t}</span>
									))}
								</div>
							) : null}
						</li>
					))}
				</ol>
			)}
		</div>
	</section>
</SiteLayout>
