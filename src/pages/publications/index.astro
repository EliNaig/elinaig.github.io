---
import SiteLayout from "../../layouts/SiteLayout.astro";
import BibEntry from "../../components/BibEntry.astro";
import { getCollection, type CollectionEntry } from "astro:content";

let entries: CollectionEntry<"publications">[] = [];
try {
	entries = await getCollection("publications");
} catch {
	entries = [];
}
entries = entries.filter((e) => !e.data.draft);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const years = [...new Set(entries.map((e) => e.data.date.getUTCFullYear()))];

const publicationJsonLd = entries
	.filter((e) => e.data.status === "published")
	.map((entry) => ({
		"@context": "https://schema.org",
		"@type": "ScholarlyArticle",
		headline: entry.data.title,
		author: entry.data.authors
			? entry.data.authors.split(",").map((name: string) => ({ "@type": "Person", name: name.trim() }))
			: undefined,
		datePublished: entry.data.date.toISOString(),
		isPartOf: entry.data.venue,
		description: entry.data.summary,
		url: entry.data.links?.pdf,
	}));
---

<SiteLayout title="Publications" description="Preprints, working papers, and publications by Eli Naig.">
	{publicationJsonLd.length > 0 ? (
		<script type="application/ld+json" is:inline set:html={JSON.stringify(publicationJsonLd)}></script>
	) : null}
	<div class="post">
		<header class="post-header">
			<h1 class="post-title">Publications</h1>
			<p class="desc">Publications in reversed chronological order.</p>
		</header>

		<article>
			{entries.length === 0 ? (
				<p>No public papers posted yet.</p>
			) : (
				<div class="publications">
					{years.map((year) => (
						<>
							<h2 class="bibliography">{year}</h2>
							<ol class="bibliography">
								{entries
									.filter((e) => e.data.date.getUTCFullYear() === year)
									.map((entry) => (
										<BibEntry entry={entry} />
									))}
							</ol>
						</>
					))}
				</div>
			)}
		</article>
	</div>
</SiteLayout>
