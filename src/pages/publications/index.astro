---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

let entries = [];
try {
	entries = await getCollection("publications");
} catch {
	entries = [];
}
entries = entries.filter((e) => !e.data.draft);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const visibleEntries = entries;
const releasedEntries = entries.filter((e) => e.data.status === "published");
const patentQueueCount = entries.filter((e) => e.data.status !== "published").length;

const publicationJsonLd = releasedEntries.map((entry) => ({
	"@context": "https://schema.org",
	"@type": "ScholarlyArticle",
	headline: entry.data.title,
	author: entry.data.authors ? entry.data.authors.split(",").map((name) => ({ "@type": "Person", name: name.trim() })) : undefined,
	datePublished: entry.data.date.toISOString(),
	isPartOf: entry.data.venue,
	description: entry.data.summary,
	url: entry.data.links?.pdf,
}));

function statusLabel(status) {
	if (!status) return "Unspecified";
	if (status === "in-prep") return "In Prep";
	if (status === "preprint") return "Preprint";
	return "Published";
}
---

<SiteLayout title="Publications" description="Published papers and patent-pending research updates by Eli Naig.">
	{publicationJsonLd.length > 0 ? (
		<script type="application/ld+json" set:html={JSON.stringify(publicationJsonLd)}></script>
	) : null}
	<section class="mt-2">
		<h1>Papers</h1>
		<p class="mt-4 max-w-prose text-zinc-800">
			Selected papers and preprints are listed below. For talks and teaching, see <a href="/work/">Work</a>.
		</p>
		<div class="mt-6 max-w-3xl rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<div class="prose max-w-none">
				{visibleEntries.length === 0 ? (
					<p class="rounded-sm border border-zinc-200 bg-zinc-50 p-4">No public papers posted yet.</p>
				) : (
					<ol class="space-y-5 !pl-0">
						{visibleEntries.map((e) => (
							<li class="list-none rounded-sm border border-zinc-200 bg-zinc-50 p-4">
								<div class="flex flex-wrap items-start justify-between gap-3">
									<strong class="text-zinc-950">{e.data.title}</strong>
									<span class="pill">{statusLabel(e.data.status)}</span>
								</div>
								{e.data.authors ? <div class="mt-1 text-zinc-700">{e.data.authors}</div> : null}
								<div class="mt-1 text-zinc-600">
									{e.data.venue ? `${e.data.venue} • ` : ""}
									{e.data.date.toLocaleDateString(undefined, { year: "numeric", month: "short" })}
								</div>
								{e.data.summary ? <p class="mt-3 text-sm text-zinc-700">{e.data.summary}</p> : null}
								{e.data.tags?.length ? (
									<div class="mt-3 flex flex-wrap gap-2">
										{e.data.tags.map((tag) => (
											<span class="pill">{tag}</span>
										))}
									</div>
								) : null}
								{e.data.links ? (
									<div class="mt-3 flex flex-wrap gap-3 text-sm">
										{e.data.links.pdf ? <a class="no-underline hover:underline" href={e.data.links.pdf}>PDF</a> : null}
										{e.data.links.arxiv ? <a class="no-underline hover:underline" href={e.data.links.arxiv}>arXiv</a> : null}
										{e.data.links.eprint ? <a class="no-underline hover:underline" href={e.data.links.eprint}>ePrint</a> : null}
										{e.data.links.code ? <a class="no-underline hover:underline" href={e.data.links.code}>Code</a> : null}
										{e.data.links.project ? <a class="no-underline hover:underline" href={e.data.links.project}>Project</a> : null}
									</div>
								) : null}
							</li>
						))}
					</ol>
				)}
			</div>
		</div>
	</section>
</SiteLayout>
