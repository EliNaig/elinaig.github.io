---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

let entries = [];
try {
	entries = await getCollection("publications");
} catch {
	entries = [];
}
entries = entries.filter((e) => !e.data.draft);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const visibleEntries = entries;
const releasedEntries = entries.filter((e) => e.data.status === "published");
const submittedEntries = visibleEntries.filter((e) => e.data.status !== "published");
const publishedEntries = visibleEntries.filter((e) => e.data.status === "published");

const publicationJsonLd = releasedEntries.map((entry) => ({
	"@context": "https://schema.org",
	"@type": "ScholarlyArticle",
	headline: entry.data.title,
	author: entry.data.authors ? entry.data.authors.split(",").map((name) => ({ "@type": "Person", name: name.trim() })) : undefined,
	datePublished: entry.data.date.toISOString(),
	isPartOf: entry.data.venue,
	description: entry.data.summary,
	url: entry.data.links?.pdf,
}));

function publicationYear(date) {
	return date.toLocaleDateString(undefined, { year: "numeric" });
}
---

<SiteLayout title="Publications" description="Published papers and patent-pending research updates by Eli Naig.">
	{publicationJsonLd.length > 0 ? (
		<script type="application/ld+json" set:html={JSON.stringify(publicationJsonLd)}></script>
	) : null}
	<section class="mt-2 max-w-5xl">
		<h1>Publications</h1>
		<p class="mt-4 max-w-3xl text-zinc-800">
			My preprints and publications are listed below. For talks and teaching, see <a href="/work/">Work</a>.
		</p>

		{visibleEntries.length === 0 ? (
			<p class="mt-8 text-zinc-700">No public papers posted yet.</p>
		) : (
			<div class="mt-8 space-y-10">
				{submittedEntries.length ? (
					<section>
						<h2>Submitted</h2>
						<ol class="mt-4 list-decimal space-y-4 pl-8 text-zinc-800 marker:text-zinc-700">
							{submittedEntries.map((e) => (
								<li class="pl-2 leading-7">
									{e.data.authors ? `${e.data.authors}. ` : ""}
									{`(${publicationYear(e.data.date)}). `}
									<span>{e.data.title}.</span>
									{e.data.venue ? ` ${e.data.venue}.` : ""}
									{e.data.links?.pdf ? <span> <a href={e.data.links.pdf}>[PDF]</a></span> : null}
									{e.data.links?.arxiv ? <span> <a href={e.data.links.arxiv}>[arXiv]</a></span> : null}
									{e.data.links?.eprint ? <span> <a href={e.data.links.eprint}>[ePrint]</a></span> : null}
									{e.data.links?.code ? <span> <a href={e.data.links.code}>[code]</a></span> : null}
								</li>
							))}
						</ol>
					</section>
				) : null}

				{publishedEntries.length ? (
					<>
						<hr />
						<section>
							<h2>Published</h2>
							<ol class="mt-4 list-decimal space-y-4 pl-8 text-zinc-800 marker:text-zinc-700" start={submittedEntries.length + 1}>
								{publishedEntries.map((e) => (
									<li class="pl-2 leading-7">
										{e.data.authors ? `${e.data.authors}. ` : ""}
										{`(${publicationYear(e.data.date)}). `}
										<span>{e.data.title}.</span>
										{e.data.venue ? ` ${e.data.venue}.` : ""}
										{e.data.links?.pdf ? <span> <a href={e.data.links.pdf}>[PDF]</a></span> : null}
										{e.data.links?.arxiv ? <span> <a href={e.data.links.arxiv}>[arXiv]</a></span> : null}
										{e.data.links?.eprint ? <span> <a href={e.data.links.eprint}>[ePrint]</a></span> : null}
										{e.data.links?.code ? <span> <a href={e.data.links.code}>[code]</a></span> : null}
									</li>
								))}
							</ol>
						</section>
					</>
				) : null}
			</div>
		)}
	</section>
</SiteLayout>
