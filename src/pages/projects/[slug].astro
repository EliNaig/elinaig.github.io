---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { site } from "../../lib/site";

export async function getStaticPaths() {
	let entries = [];
	try {
		entries = await getCollection("projects");
	} catch {
		entries = [];
	}
	entries = entries.filter((e) => !e.data.draft && e.slug === "anti-chain-posetbench");
	return entries.map((e) => ({ params: { slug: e.slug }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const projectUrl = new URL(`/projects/${entry.slug}/`, site.url).href;
const structuredData = {
	"@context": "https://schema.org",
	"@type": "CreativeWork",
	name: entry.data.title,
	description: entry.data.summary,
	url: projectUrl,
	keywords: entry.data.tags?.join(", "),
	creator: {
		"@type": "Person",
		name: site.name,
	},
};
---

<SiteLayout title={entry.data.title} description={entry.data.summary ?? undefined} structuredData={structuredData}>
	<section class="mt-2">
		<div class="max-w-prose">
			<p class="text-sm text-zinc-600">
				<a class="no-underline hover:underline" href="/work/">Work</a>
				<span class="mx-2 text-zinc-300">/</span>
				<span>{entry.data.title}</span>
			</p>
			<h1 class="mt-2">{entry.data.title}</h1>
			{entry.data.summary ? <p class="mt-3 text-zinc-800">{entry.data.summary}</p> : null}
			<div class="mt-4 grid gap-2 text-sm text-zinc-700">
				{entry.data.role ? (
					<p>
						<strong class="text-zinc-900">Role:</strong> {entry.data.role}
					</p>
				) : null}
				{entry.data.impact ? (
					<p>
						<strong class="text-zinc-900">Impact:</strong> {entry.data.impact}
					</p>
				) : null}
			</div>
		</div>

		<article class="prose mt-8 max-w-prose">
			<Content />
		</article>
	</section>
</SiteLayout>
