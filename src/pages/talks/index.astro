---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

let entries = [];
try {
	entries = await getCollection("talks");
} catch {
	entries = [];
}
entries = entries.filter((e) => !e.data.draft);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SiteLayout title="Talks" description="Talks, posters, and seminar presentations by Eli Naig.">
	<section class="mt-2">
		<h1>Talks</h1>
		<p class="mt-4 max-w-prose text-zinc-800">
			Talks, posters, and seminar presentations. For publications and teaching, see <a href="/work/">Work</a>.
		</p>
		<div class="mt-6 max-w-3xl rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<div class="prose max-w-none">
				{entries.length === 0 ? (
					<p class="rounded-sm border border-zinc-200 bg-zinc-50 p-4">No entries yet. Add Markdown files under <code>src/content/talks/</code>.</p>
				) : (
					<ul class="space-y-4 !pl-0">
						{entries.map((e) => (
							<li class="list-none rounded-sm border border-zinc-200 bg-zinc-50 p-4">
								<div class="flex flex-wrap items-start justify-between gap-3">
									<strong class="text-zinc-950">{e.data.title}</strong>
									{e.data.kind ? <span class="pill capitalize">{e.data.kind}</span> : null}
								</div>
								<div class="mt-1 text-zinc-600">
									{e.data.event ? `${e.data.event} • ` : ""}
									{e.data.location ? `${e.data.location} • ` : ""}
									{e.data.date.toLocaleDateString(undefined, { year: "numeric", month: "short" })}
								</div>
								{e.data.summary ? <p class="mt-2 text-sm text-zinc-700">{e.data.summary}</p> : null}
								{e.data.tags?.length ? (
									<div class="mt-3 flex flex-wrap gap-2">
										{e.data.tags.map((tag) => (
											<span class="pill">{tag}</span>
										))}
									</div>
								) : null}
								{e.data.links ? (
									<div class="mt-3 flex flex-wrap gap-3 text-sm">
										{e.data.links.slides ? <a class="no-underline hover:underline" href={e.data.links.slides}>Slides</a> : null}
										{e.data.links.video ? <a class="no-underline hover:underline" href={e.data.links.video}>Video</a> : null}
									</div>
								) : null}
							</li>
						))}
					</ul>
				)}
			</div>
		</div>
	</section>
</SiteLayout>
