---
import SiteLayout from "../layouts/SiteLayout.astro";
import BibEntry from "../components/BibEntry.astro";
import SocialIcons from "../components/SocialIcons.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { site } from "../lib/site";

let publications: CollectionEntry<"publications">[] = [];
try {
	publications = await getCollection("publications");
} catch {
	publications = [];
}
const selectedPublications = publications
	.filter((e) => !e.data.draft && e.data.selected)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Person",
			name: site.name,
			url: site.url,
			email: site.email,
			jobTitle: "Mathematics Student and Undergraduate Researcher",
			affiliation: {
				"@type": "CollegeOrUniversity",
				name: site.affiliation,
			},
			sameAs: [
				site.social.github,
				site.social.linkedin,
				site.social.orcid,
			].filter(Boolean),
		},
		{
			"@type": "WebSite",
			name: `${site.name} Personal Website`,
			url: site.url,
		},
	],
};
---

<SiteLayout
	title="Home"
	description="Eli Naig is a mathematics undergraduate at Tulane University working on algebraic coding theory and post-quantum cryptography."
	structuredData={structuredData}
>
	<div class="post">
		<header class="post-header">
			<h1 class="post-title"><strong>Eli</strong> Naig</h1>
			<p class="desc">
				Mathematics @ {site.affiliation} • coding theory • post-quantum cryptography
			</p>
		</header>

		<article>
			<div class="profile float-right">
				<img
					src={site.profileImage}
					alt={`Portrait of ${site.name}`}
					width="1600"
					height="2400"
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
				<div class="more-info">
					<p>{site.location}</p>
					<br />
					<p>{site.affiliation}</p>
					<br />
					<p><a href={`mailto:${site.email}`}>{site.email}</a></p>
				</div>
			</div>

			<div class="clearfix">
				<p>
					I'm a mathematics undergraduate at {site.affiliation},
					working with <a href="https://mahirbilencan.github.io/"
						>Mahir Bilen Can</a
					> on algebraic coding theory and code-based post-quantum cryptography.
					I also co-founded <a href="https://www.qsparclabs.com/"
						>QSPARC Labs</a
					>, where we build software based on this research.
				</p>
				<p>
					This summer I am at the University of South Carolina's NSF
					REU in quantum information science, working with <a
						href="https://cse.sc.edu/~fenner/">Stephen Fenner</a
					> on quantum position verification. I am applying to PhD programs
					for Fall 2027. The best way to reach me is by email at <a
						href={`mailto:${site.email}`}>{site.email}</a
					>; my CV is <a href="/cv/">here</a>.
				</p>
			</div>

			{
				selectedPublications.length > 0 ? (
					<>
						<h2>
							<a href="/publications/" style="color: inherit;">
								Selected Publications
							</a>
						</h2>
						<div class="publications">
							<ol class="bibliography">
								{selectedPublications.map((entry) => (
									<BibEntry entry={entry} />
								))}
							</ol>
						</div>
					</>
				) : null
			}

			<h2>Leadership</h2>
			<div>
				<div
					class="flex flex-col gap-6 sm:flex-row sm:items-start"
					style="margin-bottom: 2rem;"
				>
					<img
						src="/images/tulane-scioly-logo.png"
						alt="Tulane Science Olympiad logo"
						class="h-24 w-24 shrink-0 object-contain"
						loading="lazy"
					/>
					<div>
						<h5>
							Co-Founder and Vice President, Tulane Science
							Olympiad
						</h5>
						<p class="text-muted" style="margin-bottom: 0.5rem;">
							2024-Present
						</p>
						<p>
							Co-founded Tulane’s first Science Olympiad
							invitational and helped drive rapid growth in
							Science Olympiad at Tulane and across Louisiana.
							Work includes statewide outreach, tournament
							organizing, volunteer coordination, campus-wide
							space allocation across 60+ classrooms and
							laboratories, and development of the official
							competition website, all in support of an effort to
							expand active Science Olympiad teams statewide.
						</p>
						<p>
							<a href="https://www.tulanescioly.org/"
								>tulanescioly.org</a
							>
						</p>
					</div>
				</div>
				<div class="flex flex-col gap-6 sm:flex-row sm:items-start">
					<img
						src="/images/tulane-math-club-logo.png"
						alt="Tulane Math Club logo"
						class="h-24 w-24 shrink-0 object-contain"
						loading="lazy"
					/>
					<div>
						<h5>President, Tulane Math Club</h5>
						<p class="text-muted" style="margin-bottom: 0.5rem;">
							2026-2027
						</p>
						<p>
							During the 2026-2027 academic year, I lead club
							programming, coordination, student engagement, and
							stewardship of the organization website.
						</p>
						<p>
							<a href="https://tulanemathsociety.github.io/"
								>tulanemathsociety.github.io</a
							>
						</p>
					</div>
				</div>
			</div>

			<div class="social">
				<div class="contact-icons">
					<SocialIcons />
				</div>
				<div class="contact-note">
					The best way to reach me is by email.
				</div>
			</div>
		</article>
	</div>
</SiteLayout>
