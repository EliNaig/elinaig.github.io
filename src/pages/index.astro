---
import SiteLayout from "../layouts/SiteLayout.astro";
import { site } from "../lib/site";
import { getCollection } from "astro:content";

let publications = [];
try {
	publications = await getCollection("publications");
} catch {
	publications = [];
}

publications = publications.filter((e) => !e.data.draft);

const publishedPaperCount = publications.filter((e) => e.data.status === "published").length;
const preprintPaperCount = publications.filter((e) => e.data.status === "preprint").length;
const inPrepPaperCount = publications.filter((e) => e.data.status === "in-prep").length;
const publicPaperCount = publishedPaperCount + preprintPaperCount;

const proofPoints = [
	"B.S. Mathematics at Tulane University (2024-2027)",
	"Cumulative GPA: 3.97 / 4.00",
	"Undergraduate research in algebraic coding theory + PQC",
	"Co-Founder and Vice President, Tulane Science Olympiad",
	"President, Tulane Math Club (2026-2027)",
];

const paperPipelineNotes = [
	`Public research writing: ${publicPaperCount} item${publicPaperCount === 1 ? "" : "s"}.`,
	`Currently posted: ${preprintPaperCount} preprint${preprintPaperCount === 1 ? "" : "s"} and ${publishedPaperCount} published paper${publishedPaperCount === 1 ? "" : "s"}.`,
	inPrepPaperCount
		? `${inPrepPaperCount} additional manuscript${inPrepPaperCount === 1 ? "" : "s"} in preparation.`
		: "Additional manuscripts are in active development.",
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Person",
			name: site.name,
			url: site.url,
			email: site.email,
			jobTitle: "Mathematics Student and Undergraduate Researcher",
			affiliation: {
				"@type": "CollegeOrUniversity",
				name: site.affiliation,
			},
			sameAs: [site.social.github, site.social.linkedin, site.social.orcid].filter(Boolean),
		},
		{
			"@type": "WebSite",
			name: `${site.name} Personal Website`,
			url: site.url,
		},
	],
};
---

<SiteLayout
	title="Home"
	description="Building post-quantum cryptography from algebraic theory to reproducible implementation."
	structuredData={structuredData}
>
	<div class="space-y-10">
		<section class="max-w-3xl">
			<h1 class="text-4xl font-semibold leading-tight text-zinc-950 sm:text-5xl">
				Eli Naig: Coding Theory, Metric Properties, and PQC
			</h1>
			<p class="mt-5 text-base leading-7 text-zinc-800">
				I’m {site.name}, a mathematics student and undergraduate researcher at {site.affiliation} working on algebraic coding
				theory, NRT metrics, and reproducible post-quantum cryptography systems.
			</p>
			<div class="mt-6 flex flex-wrap gap-3">
				<a class="btn-primary" href="/publications/">Publications</a>
				<a class="btn-secondary" href="/cv/">Read CV</a>
			</div>
		</section>

		<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<h2 class="text-2xl font-semibold tracking-tight text-zinc-950">At a glance</h2>
			<div class="mt-5 grid gap-3 sm:grid-cols-2">
				{proofPoints.map((point) => (
					<div class="rounded-sm border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm text-zinc-800">{point}</div>
				))}
			</div>
		</section>

		<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<div class="prose max-w-none">
				<h2>Research focus</h2>
				<p>
					I work on algebraic methods in coding theory and cryptography, with an emphasis on building strong fundamentals and
					writing clear expository notes.
				</p>
				<ul>
					<li><strong>Algebraic coding theory:</strong> structural and metric properties of code families.</li>
					<li><strong>Algebraic geometry:</strong> foundations and examples that inform code structure.</li>
					<li><strong>Post-quantum cryptography:</strong> code-based KEM design and analysis.</li>
					<li><strong>Number theory and cryptography:</strong> mathematical tools for secure constructions.</li>
					<li><strong>Reproducible systems:</strong> benchmark harnesses, conformance vectors, and experiment pipelines.</li>
				</ul>
				<h2>Current research</h2>
				<ul>
					<li>
						Undergraduate research with <a href="https://mahirbilencan.github.io/">Mahir Bilen Can</a> at Tulane University
					</li>
					<li>
						Selected papers and public research writing live on <a href="/publications/">Publications</a>.
					</li>
				</ul>
			</div>
		</section>

		<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<div class="prose max-w-none">
				<h2>Current focus</h2>
				<ul>
					<li>Building reproducible benchmark pipelines for post-quantum coding and decoding experiments.</li>
					<li>Developing and validating QC/Niederreiter-style implementation references.</li>
					<li>Expanding project documentation into publication-ready technical artifacts.</li>
				</ul>

				<h2>Active reading</h2>
				<ul>
					<li>Algebraic coding theory and metric-structured code families</li>
					<li>Cryptographic implementation and evaluation methodology</li>
				</ul>

				<h2>Outside the technical work</h2>
				<p>
					I’m drawn to scientific biography and computing history; favorites include <em>Surely You're Joking, Mr.
					Feynman!</em>, <em>The Bit Player</em>, and <em>The Imitation Game</em>.
				</p>

				<h2>Open to</h2>
				<ul>
					<li>Research collaboration in coding theory and post-quantum cryptography</li>
					<li>Seminar talks and technical discussions</li>
					<li>Graduate-level opportunities in mathematics and cryptography</li>
				</ul>
			</div>
		</section>

		<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<div class="max-w-5xl">
				<h2 class="text-2xl font-semibold tracking-tight text-zinc-950">Leadership</h2>
				<div class="mt-8 space-y-8">
					<article class="grid gap-6 sm:grid-cols-[8rem_minmax(0,1fr)] sm:items-start">
						<img
							src="/images/tulane-scioly-logo.png"
							alt="Tulane Science Olympiad logo"
							class="h-28 w-28 shrink-0 object-contain"
							loading="lazy"
						/>
						<div class="min-w-0">
							<p class="text-xl leading-8 text-zinc-900">
								<strong>Co-Founder and Vice President, Tulane Science Olympiad</strong> — 2024-Present
							</p>
							<p class="mt-4 text-lg leading-8 text-zinc-800">
								Co-founded Tulane’s first Science Olympiad invitational and helped drive rapid growth in Science Olympiad
								at Tulane and across Louisiana. Work includes statewide outreach, tournament organizing, volunteer
								coordination, campus-wide space allocation across 60+ classrooms and laboratories, and development of the
								official competition website, all in support of an effort to expand active Science Olympiad teams statewide.
							</p>
							<p class="mt-5 text-lg">
								<a href="https://www.tulanescioly.org/">Visit tulanescioly.org</a>
							</p>
						</div>
					</article>
					<hr />
					<article class="grid gap-6 sm:grid-cols-[8rem_minmax(0,1fr)] sm:items-start">
						<img
							src="/images/tulane-math-club-logo.png"
							alt="Tulane Math Club logo"
							class="h-28 w-28 shrink-0 object-contain"
							loading="lazy"
						/>
						<div class="min-w-0">
							<p class="text-xl leading-8 text-zinc-900">
								<strong>President, Tulane Math Club</strong> — 2026-2027
							</p>
							<p class="mt-4 text-lg leading-8 text-zinc-800">
								During the 2026-2027 academic year, I lead club programming, coordination, student engagement, and
								stewardship of the organization website.
							</p>
							<p class="mt-5 text-lg">
								<a href="https://tulanemathsociety.github.io/">Visit tulanemathsociety.github.io</a>
							</p>
						</div>
					</article>
				</div>
			</div>
		</section>

		<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<div class="prose max-w-none">
				<h2>Publications snapshot</h2>
				<ul>
					{paperPipelineNotes.map((item) => (
						<li>{item}</li>
					))}
				</ul>
				<p>
					Public research writing lives on <a href="/publications/">Publications</a>. Currently visible:
					<strong>{publicPaperCount}</strong>. For a consolidated view, visit <a href="/publications/">Publications</a> and
					<a href="/cv/">CV</a>.
				</p>
			</div>
		</section>

		<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<h2 class="text-2xl font-semibold tracking-tight text-zinc-950">Explore more</h2>
				<div class="mt-5 flex flex-wrap gap-2 text-sm">
					<a class="pill" href="/publications/">Publications</a>
					<a class="pill" href="/cv/">CV</a>
				</div>
			</section>

		<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<h2 class="text-2xl font-semibold tracking-tight text-zinc-950">Collaborate or connect</h2>
			<p class="mt-3 max-w-2xl text-zinc-800">
				If you’re reaching out about research collaboration, graduate study opportunities, technical project work, or speaking,
				email me at <a href={`mailto:${site.email}`}>{site.email}</a>.
			</p>
			<p class="mt-4 max-w-2xl text-zinc-800">
				If you email about research, a reading group, or collaboration, a couple of sentences on context and timeline help.
			</p>
			<div class="mt-5 flex flex-wrap gap-3">
				<a class="btn-primary" href={`mailto:${site.email}`}>Email</a>
				<a class="btn-secondary" href="/publications/">Publications</a>
			</div>
		</section>
	</div>
</SiteLayout>
