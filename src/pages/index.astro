---
import SiteLayout from "../layouts/SiteLayout.astro";
import { site } from "../lib/site";

const facts = [
	{ label: "Education", value: "B.S. Mathematics, Tulane University, expected 2027 · GPA 3.97 / 4.00" },
	{ label: "Advisor", value: "Mahir Bilen Can, Tulane University", href: "https://mahirbilencan.github.io/" },
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Person",
			name: site.name,
			url: site.url,
			email: site.email,
			jobTitle: "Mathematics Student and Undergraduate Researcher",
			affiliation: {
				"@type": "CollegeOrUniversity",
				name: site.affiliation,
			},
			sameAs: [site.social.github, site.social.linkedin, site.social.orcid].filter(Boolean),
		},
		{
			"@type": "WebSite",
			name: `${site.name} Personal Website`,
			url: site.url,
		},
	],
};
---

<SiteLayout
	title="Home"
	description="Building post-quantum cryptography from algebraic theory to reproducible implementation."
	structuredData={structuredData}
>
	<div class="space-y-12">
		<section class="max-w-3xl">
			<p class="mb-4 text-sm uppercase tracking-[0.18em] text-zinc-500">Mathematics • Coding theory • Cryptography</p>
			<h1>
				I study algebraic coding theory and post-quantum cryptography.
			</h1>
			<p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-700">
				I’m {site.name}, a mathematics undergraduate at {site.affiliation}. My work centers on the metric and algebraic
				structure of code families and on building reproducible systems for cryptographic research.
			</p>
			<div class="mt-8 flex flex-wrap gap-3">
				<a class="btn-primary" href="/publications/">Publications</a>
				<a class="btn-secondary" href="/cv/">Read CV</a>
			</div>
		</section>

		<section class="section">
			<dl class="grid gap-8 sm:grid-cols-2">
				{facts.map((fact) => (
					<div>
						<dt class="text-sm font-medium uppercase tracking-[0.16em] text-zinc-500">{fact.label}</dt>
						<dd class="mt-3 text-sm leading-6 text-zinc-700">
							{fact.href ? <a href={fact.href}>{fact.value}</a> : fact.value}
						</dd>
					</div>
				))}
			</dl>
		</section>

		<section class="section">
			<div class="grid gap-x-8 gap-y-4 lg:grid-cols-[11rem_minmax(0,1fr)]">
				<h2>Research focus</h2>
				<div class="prose max-w-none">
					<p>
						I work on algebraic methods in coding theory and cryptography, with an emphasis on building strong fundamentals and
						writing clear expository notes.
					</p>
					<ul>
						<li><strong>Algebraic coding theory:</strong> structural and metric properties of code families.</li>
						<li><strong>Algebraic geometry:</strong> foundations and examples that inform code structure.</li>
						<li><strong>Post-quantum cryptography:</strong> code-based KEM design and analysis.</li>
						<li><strong>Number theory and cryptography:</strong> mathematical tools for secure constructions.</li>
						<li><strong>Reproducible systems:</strong> benchmark harnesses, conformance vectors, and experiment pipelines.</li>
					</ul>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="grid gap-x-8 gap-y-4 lg:grid-cols-[11rem_minmax(0,1fr)]">
				<h2>Outside the technical work</h2>
				<div class="prose max-w-none">
					<p>
						I’m drawn to scientific biography and computing history; favorites include <em>Surely You're Joking, Mr.
						Feynman!</em>, <em>The Bit Player</em>, and <em>The Imitation Game</em>.
					</p>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="grid gap-x-8 gap-y-4 lg:grid-cols-[11rem_minmax(0,1fr)]">
				<h2>Leadership</h2>
				<div class="min-w-0 divide-y divide-zinc-200">
					<article class="grid gap-6 py-6 first:pt-0 sm:grid-cols-[7rem_minmax(0,1fr)] sm:items-start">
						<img
							src="/images/tulane-scioly-logo.png"
							alt="Tulane Science Olympiad logo"
							class="h-24 w-24 shrink-0 object-contain"
							loading="lazy"
						/>
						<div class="min-w-0">
							<h3>Co-Founder and Vice President, Tulane Science Olympiad</h3>
							<p class="mt-1 text-sm text-zinc-500">2024-Present</p>
							<p class="mt-3 max-w-2xl">
								Co-founded Tulane’s first Science Olympiad invitational and helped drive rapid growth in Science Olympiad
								at Tulane and across Louisiana. Work includes statewide outreach, tournament organizing, volunteer
								coordination, campus-wide space allocation across 60+ classrooms and laboratories, and development of the
								official competition website, all in support of an effort to expand active Science Olympiad teams statewide.
							</p>
							<p class="mt-4 text-sm">
								<a href="https://www.tulanescioly.org/">Visit tulanescioly.org</a>
							</p>
						</div>
					</article>
					<article class="grid gap-6 py-6 last:pb-0 sm:grid-cols-[7rem_minmax(0,1fr)] sm:items-start">
						<img
							src="/images/tulane-math-club-logo.png"
							alt="Tulane Math Club logo"
							class="h-24 w-24 shrink-0 object-contain"
							loading="lazy"
						/>
						<div class="min-w-0">
							<h3>President, Tulane Math Club</h3>
							<p class="mt-1 text-sm text-zinc-500">2026-2027</p>
							<p class="mt-3 max-w-2xl">
								During the 2026-2027 academic year, I lead club programming, coordination, student engagement, and
								stewardship of the organization website.
							</p>
							<p class="mt-4 text-sm">
								<a href="https://tulanemathsociety.github.io/">Visit tulanemathsociety.github.io</a>
							</p>
						</div>
					</article>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="grid gap-x-8 gap-y-4 lg:grid-cols-[11rem_minmax(0,1fr)]">
				<h2>Collaborate</h2>
				<div class="min-w-0">
					<p class="max-w-2xl text-zinc-700">
						I’m open to research collaboration in coding theory and post-quantum cryptography, seminar talks and technical
						discussions, project work, and graduate-level opportunities in mathematics.
					</p>
					<p class="mt-4 max-w-2xl text-zinc-700">
						If you’re reaching out about any of these, <a href={`mailto:${site.email}`}>email me</a>. A couple of sentences on
						context and timeline help.
					</p>
				</div>
			</div>
		</section>
	</div>
</SiteLayout>
