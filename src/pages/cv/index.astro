---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { site } from "../../lib/site";
---

<SiteLayout title="CV" description="Curriculum vitae for Eli Naig, including research and academic experience.">
	<div class="post">
		<header class="post-header">
			<h1 class="post-title">CV</h1>
			<p class="desc">
				<a href="/ENCV.pdf">Download as PDF</a> · <a href={`mailto:${site.email}`}>{site.email}</a>
			</p>
		</header>

		<article>
			<p class="text-muted" style="font-size: 0.875rem;">
				On mobile devices, downloading the PDF is often easier than embedded viewing.
			</p>

			<div style="border: 1px solid var(--global-divider-color); border-radius: 0.25rem; overflow: hidden;">
				<iframe title="CV PDF" src="/ENCV.pdf#view=FitH" class="h-[80vh] w-full"></iframe>
			</div>
		</article>
	</div>
</SiteLayout>
