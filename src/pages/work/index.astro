---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

async function safeCollection(name) {
	try {
		return await getCollection(name);
	} catch {
		return [];
	}
}

const antiChain = (await safeCollection("projects")).find((e) => !e.data.draft && e.slug === "anti-chain-posetbench");

let teaching = (await safeCollection("teaching")).filter((e) => !e.data.draft);
teaching.sort((a, b) => String(b.data.term).localeCompare(String(a.data.term)));
const featuredTeaching = teaching.slice(0, 3);
---

<SiteLayout title="Work" description="Patent-backed project, teaching, and STEM outreach leadership.">
	<div class="space-y-10">
		<section class="max-w-2xl">
			<h1>Work</h1>
			<p class="mt-4 text-base leading-7 text-zinc-800">
				A single place to browse patent-backed work, teaching, and STEM outreach leadership.
			</p>
		</section>

		<div class="grid gap-6 lg:grid-cols-2">
			<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
				<div class="prose max-w-none">
					<h2>Patent-backed project</h2>
					{antiChain ? (
						<ul>
							<li>
								<a href={`/projects/${antiChain.slug}/`}>{antiChain.data.title}</a>
								{antiChain.data.summary ? <div class="text-zinc-700">{antiChain.data.summary}</div> : null}
							</li>
						</ul>
					) : (
						<p>Anti-Chain project details will appear here soon.</p>
					)}
				</div>
			</section>

			<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
				<div class="prose max-w-none">
					<h2>Teaching</h2>
					<ul>
						{featuredTeaching.map((c) => (
							<li>
								<a href="/teaching/">{c.data.course}</a>
								<div class="text-zinc-700">
									{c.data.term}{c.data.institution ? ` • ${c.data.institution}` : ""}{c.data.role ? ` • ${c.data.role}` : ""}
								</div>
							</li>
						))}
					</ul>
					<p><a href="/teaching/">Browse all teaching</a></p>
				</div>
			</section>
		</div>

		<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
			<div class="grid gap-6 md:grid-cols-[120px_1fr] md:items-start">
				<a
					href="https://www.tulanescioly.org/"
					aria-label="Tulane Science Olympiad website"
					class="inline-flex h-28 w-28 items-center justify-center no-underline"
				>
					<img
						src="/images/tulane-scioly-logo.png"
						alt="Tulane Science Olympiad logo"
						class="max-h-full max-w-full object-contain"
						loading="lazy"
					/>
				</a>
				<div class="prose max-w-none">
					<h2>STEM outreach leadership</h2>
					<p>
						<strong>Co-Founder and Vice President, Tulane Science Olympiad</strong> — 2024–Present
					</p>
					<p>
						Co-founded Tulane’s first Science Olympiad invitational and led logistical planning for a large-scale
						competition hosting 13 teams and 450+ students from multiple states. Work includes statewide outreach,
						tournament organizing, volunteer coordination, campus-wide space allocation across 60+ classrooms and
						laboratories, and development of the official competition website.
					</p>
					<p>
						<a href="https://www.tulanescioly.org/">Visit tulanescioly.org</a>
					</p>
				</div>
			</div>
		</section>
	</div>
</SiteLayout>
