---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

async function safeCollection(name) {
	try {
		return await getCollection(name);
	} catch {
		return [];
	}
}

const antiChain = (await safeCollection("projects")).find((e) => !e.data.draft && e.slug === "anti-chain-posetbench");

let teaching = (await safeCollection("teaching")).filter((e) => !e.data.draft);
teaching.sort((a, b) => String(b.data.term).localeCompare(String(a.data.term)));
const featuredTeaching = teaching.slice(0, 3);

let writing = (await safeCollection("writing")).filter((e) => !e.data.draft);
writing.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredWriting = writing.slice(0, 3);
---

<SiteLayout title="Work" description="Patent-backed project, teaching, and writing.">
	<div class="space-y-10">
		<section class="max-w-2xl">
			<h1>Work</h1>
			<p class="mt-4 text-base leading-7 text-zinc-800">
				A single place to browse patent-backed work, teaching, and writing.
			</p>
		</section>

		<div class="grid gap-6 lg:grid-cols-2">
			<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
				<div class="prose max-w-none">
					<h2>Patent-backed project</h2>
					{antiChain ? (
						<ul>
							<li>
								<a href={`/projects/${antiChain.slug}/`}>{antiChain.data.title}</a>
								{antiChain.data.summary ? <div class="text-zinc-700">{antiChain.data.summary}</div> : null}
							</li>
						</ul>
					) : (
						<p>Anti-Chain project details will appear here soon.</p>
					)}
				</div>
			</section>

			<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm">
				<div class="prose max-w-none">
					<h2>Teaching</h2>
					<ul>
						{featuredTeaching.map((c) => (
							<li>
								<a href="/teaching/">{c.data.course}</a>
								<div class="text-zinc-700">
									{c.data.term}{c.data.institution ? ` • ${c.data.institution}` : ""}{c.data.role ? ` • ${c.data.role}` : ""}
								</div>
							</li>
						))}
					</ul>
					<p><a href="/teaching/">Browse all teaching</a></p>
				</div>
			</section>

			<section class="rounded-sm border border-zinc-200/80 bg-white p-6 shadow-sm lg:col-span-2">
				<div class="prose max-w-none">
					<h2>Writing</h2>
					<ul>
						{featuredWriting.map((w) => (
							<li>
								<a href={`/writing/${w.slug}/`}>{w.data.title}</a>
								<div class="text-zinc-700">{w.data.summary}</div>
							</li>
						))}
					</ul>
					<p><a href="/writing/">Browse all writing</a></p>
				</div>
			</section>
		</div>
	</div>
</SiteLayout>
